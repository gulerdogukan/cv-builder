# ────────────────────────────────────────────────────────────────
# CV Builder — Geliştirme Ortamı Değişkenleri
# Bu dosyayı kopyala: cp .env.example .env  (veya Windows: copy .env.example .env)
# .env dosyası .gitignore'da; commit'leme!
# ────────────────────────────────────────────────────────────────

# ── SUPABASE (zorunlu) ───────────────────────────────────────────
# https://supabase.com → Proje → Settings → API
SUPABASE_URL=https://XXXXXXXXXXXXXXXXXXXX.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-settings

# Webhook secret — istediğin herhangi bir şifre olabilir (dev için)
SUPABASE_WEBHOOK_SECRET=dev-webhook-secret-degistir

# ── ANTHROPIC (zorunlu — AI özellikleri için) ────────────────────
# https://console.anthropic.com → API Keys → Create Key
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── IYZICO (opsiyonel — ödeme devre dışı bırakılabilir) ─────────
# https://sandbox.iyzipay.com → Ayarlar → API Bilgileri
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
