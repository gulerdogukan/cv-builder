# ────────────────────────────────────────────────────────────────
# CV Builder — Geliştirme Ortamı Değişkenleri
# Bu dosyayı kopyala: cp .env.example .env  (veya Windows: copy .env.example .env)
# .env dosyası .gitignore'da; commit'leme!
# ────────────────────────────────────────────────────────────────

# ── SUPABASE (zorunlu) ───────────────────────────────────────────
# https://supabase.com → Proje → Settings → API
SUPABASE_URL=https://XXXXXXXXXXXXXXXXXXXX.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-settings

# Webhook secret — istediğin herhangi bir şifre olabilir (dev için)
SUPABASE_WEBHOOK_SECRET=dev-webhook-secret-degistir

# ── GEMINI (zorunlu — AI özellikleri için) ──────────────────────
# https://aistudio.google.com/app/apikey → Create API Key
GEMINI_API_KEY=AIzaSy...
# İsteğe bağlı: model override (varsayılanlar docker-compose.yml'de tanımlı)
# GEMINI_FLASH_MODEL=gemini-2.0-flash       # karmaşık görevler
# GEMINI_LITE_MODEL=gemini-2.0-flash-lite   # basit/hızlı görevler

# ── INTERNAL SECRET (webhook / servisler arası güven token'ı) ────
# Güçlü rastgele bir değer girin: openssl rand -hex 32
INTERNAL_SECRET=

# ── IYZICO (opsiyonel — ödeme devre dışı bırakılabilir) ─────────
# https://sandbox.iyzipay.com → Ayarlar → API Bilgileri
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
