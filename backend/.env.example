# .NET reads these as env vars — set in Railway service variables panel
# Format matches appsettings.json key paths (__ = nested)

# PostgreSQL (Railway provisions this automatically if you add a Postgres plugin)
ConnectionStrings__DefaultConnection=Host=...;Port=5432;Database=railway;Username=postgres;Password=...

# Supabase
Supabase__Url=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
Supabase__AnonKey=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
Supabase__JwtSecret=your-supabase-jwt-secret

# Google Gemini API — https://aistudio.google.com/app/apikey
Gemini__ApiKey=AIzaSy...
# Gemini__FlashModel=gemini-2.0-flash       # karmaşık görevler (varsayılan)
# Gemini__LiteModel=gemini-2.0-flash-lite   # basit görevler (varsayılan)

# İyzico — https://merchant.iyzipay.com/settings/merchant
# For production: use live keys and set BaseUrl to https://api.iyzipay.com
Iyzico__ApiKey=sandbox-...
Iyzico__SecretKey=sandbox-...
Iyzico__BaseUrl=https://api.iyzipay.com

# PDF Microservice (internal Railway service URL)
PdfService__BaseUrl=https://cv-builder-pdf.railway.internal

# App
App__FrontendUrl=https://cvbuilder.app
App__CorsOrigins__0=https://cvbuilder.app
App__CorsOrigins__1=https://www.cvbuilder.app
